FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        docker.io \
        ffmpeg \
        git \
        jq \
        libsndfile1 \
        openjdk-21-jdk-headless \
        python3 \
        python3-pip \
        sox \
        unzip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
CMD ["bash"]
